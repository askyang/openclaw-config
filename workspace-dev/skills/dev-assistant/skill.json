{
  "name": "dev-assistant",
  "version": "1.1.0",
  "description": "开发助手技能包 - 全栈开发专家 + 项目管家 + 服务器监控",
  "author": "小开 (开发助手)",
  "created": "2026-04-01",
  "updated": "2026-04-01",
  "tags": [
    "development",
    "git",
    "project-management",
    "automation",
    "feishu",
    "monitoring",
    "server-management"
  ],
  "dependencies": [],
  "entryPoints": {
    "main": "SKILL.md",
    "references": [
      "references/GIT_BEST_PRACTICES.md",
      "references/PROJECT_MANAGEMENT.md"
    ],
    "scripts": [
      "scripts/daily-report.sh",
      "scripts/server-monitor.sh",
      "scripts/server-manager.py",
      "scripts/server-monitor-cron.sh"
    ]
  },
  "triggers": [
    {
      "type": "keyword",
      "patterns": [
        "开发",
        "代码",
        "git",
        "项目",
        "部署",
        "运维",
        "技术方案",
        "架构设计",
        "技能更新",
        "自我学习",
        "能力维护",
        "服务器",
        "监控",
        "告警",
        "检测",
        "状态检查"
      ]
    },
    {
      "type": "command",
      "patterns": [
        "/daily-report",
        "/git-status",
        "/project-status",
        "/server-status",
        "/server-check",
        "/server-alerts"
      ]
    }
  ],
  "capabilities": {
    "fileSystem": true,
    "git": true,
    "shell": true,
    "feishu": true,
    "webSearch": true,
    "database": true,
    "monitoring": true
  },
  "examples": [
    {
      "input": "帮我创建一个新的项目",
      "output": "我将帮您分析需求、设计技术方案、搭建项目框架..."
    },
    {
      "input": "检查Git状态",
      "output": "正在检查所有项目的Git状态..."
    },
    {
      "input": "生成工作日报",
      "output": "正在生成今日工作日报..."
    },
    {
      "input": "帮我设计一个技术方案",
      "output": "请告诉我项目需求，我将为您设计完整的技术方案..."
    },
    {
      "input": "更新你的技能",
      "output": "正在分析最近的交流记录，更新和完善技能..."
    },
    {
      "input": "检查服务器状态",
      "output": "正在检查所有服务器的运行状态..."
    },
    {
      "input": "查看服务器告警",
      "output": "正在获取当前的服务器告警信息..."
    },
    {
      "input": "监控服务器",
      "output": "正在启动服务器监控系统..."
    }
  ]
}